{
  "name": "dj-watchface",
  "version": "1.0.0",
  "description": "A DJ-themed clock face for Fitbit Versa 4",
  "private": true,
  "scripts": {
    "build": "fitbit-build",
    "debug": "fitbit"
  },
  "devDependencies": {
    "@fitbit/sdk": "~6.2.0",
    "@fitbit/sdk-cli": "^1.7.3"
  },
  "fitbit": {
    "appUUID": "66558ccf-eb27-4c82-a3b1-9e082a7d52be",
    "appType": "clockface",
    "appDisplayName": "DJ Watchface",
    "iconFile": "resources/icon.png",
    "wipeColor": "#000000",
    "requestedPermissions": [
      "access_activity",
      "access_heart_rate"
    ],
    "buildTargets": [
      "atlas"
    ],
    "i18n": {
      "en": {
        "name": "DJ Watchface"
      }
    }
  }
}
